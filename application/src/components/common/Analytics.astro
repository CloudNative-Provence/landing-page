---
import { ANALYTICS } from 'astrowind:config';

const id = ANALYTICS?.vendors?.googleAnalytics?.id ? String(ANALYTICS.vendors.googleAnalytics.id) : undefined;
const usePartytown = Boolean(ANALYTICS?.vendors?.googleAnalytics?.partytown);
---

{
  id ? (
    <script
      is:inline
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${id}`}
      type={usePartytown ? 'text/partytown' : undefined}
    />
  ) : null
}
{
  id ? (
    <script
      is:inline
      type={usePartytown ? 'text/partytown' : undefined}
      set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', ${JSON.stringify(id)});`}
    />
  ) : null
}
